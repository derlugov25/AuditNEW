{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "noEmit": true,
    "isolatedModules": false,
    "verbatimModuleSyntax": false
  },
  "include": ["scripts/**/*.ts", "scripts/**/*.mts", "src/**/*.ts", "src/**/*.tsx"]
}
